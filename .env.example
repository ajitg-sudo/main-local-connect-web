# Copy to .env on the server (cPanel → Setup Node.js App → Environment variables)

# Public site URL (your frontend domain)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Backend API
NEXT_PUBLIC_API_URL=https://iis.net.in/localconnect/api
NEXT_PUBLIC_API_ORIGIN=https://iis.net.in/localconnect
API_URL=https://iis.net.in/localconnect/api

# cPanel sets these automatically — do not override unless instructed
# NODE_ENV=production
# PORT=(assigned by cPanel)
